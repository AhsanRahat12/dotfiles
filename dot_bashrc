#
# ~/.bashrc
#

# If not running interactively, don't do anything
[[ $- != *i* ]] && return

alias ls='ls --color=auto'
alias grep='grep --color=auto'
PS1='[\u@\h \W]\$ '

# Quick date aliases for social media posts
alias today='date +%Y-%m-%d'

# Function to create dated files
function newpost {
    touch "$(date +%Y-%m-%d)-${1}"
}

# Kubectl
alias k='kubectl'
[[ -r /usr/share/bash-completion/bash_completion ]] && . /usr/share/bash-completion/bash_completion
command -v kubectl &>/dev/null && source <(kubectl completion bash)
command -v kubectl &>/dev/null && complete -o default -F __start_kubectl k
export KUBE_EDITOR=vim
export TERM=xterm-256color

### MANAGED BY RANCHER DESKTOP START (DO NOT EDIT)
export PATH="/home/rahat/.rd/bin:$PATH"
### MANAGED BY RANCHER DESKTOP END (DO NOT EDIT)

# Path for chezmoi
export PATH="$HOME/bin:$PATH"
export PATH="$HOME/.local/bin:$PATH"

# XDG Base Directory spec
export XDG_CONFIG_HOME="$HOME/.config"
export XDG_DATA_HOME="$HOME/.local/share"
export XDG_CACHE_HOME="$HOME/.cache"
export XDG_STATE_HOME="$HOME/.local/state"

command -v starship &>/dev/null && eval "$(starship init bash)"
eval "$(mise activate bash)"

# SSH Agent - loads YubiKey into agent so git can authenticate with GitHub
# Only prompts for PIN if key is not already loaded
eval $(ssh-agent) > /dev/null 2>&1
ssh-add -l &>/dev/null || ssh-add -K 2>/dev/null

# Tab completion - cycle through options
bind '"\t": menu-complete'
bind '"\e[Z": menu-complete-backward'
bind 'set show-all-if-ambiguous on'
bind 'set menu-complete-display-prefix on'

# fzf
command -v fzf &>/dev/null && eval "$(fzf --bash)"

# eza - better ls
command -v eza &>/dev/null && alias ls='eza --icons --group-directories-first'
command -v eza &>/dev/null && alias ll='eza --icons --group-directories-first -la'
command -v eza &>/dev/null && alias lt='eza --icons --tree --level=2'

# zoxide - smarter cd
command -v zoxide &>/dev/null && eval "$(zoxide init bash)"
